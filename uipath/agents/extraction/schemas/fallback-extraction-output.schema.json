{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Treatment Access Fallback Extraction Output",
  "type": "object",
  "properties": {
    "extraction_id": {
      "type": "string"
    },
    "case_id": {
      "type": "string"
    },
    "artifact_id": {
      "type": "string"
    },
    "document_class": {
      "type": "string",
      "enum": [
        "payer_policy",
        "progress_note",
        "lab_report",
        "safety_screening",
        "denial_letter"
      ]
    },
    "extraction_method": {
      "type": "string",
      "const": "fallback_parser"
    },
    "extraction_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "parser_version": {
      "type": "string"
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "field_id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "value": {},
          "normalized_value": {},
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "source_span": {
            "type": "object",
            "properties": {
              "artifact_id": {
                "type": "string"
              },
              "source_uri": {
                "type": "string"
              },
              "section_label": {
                "type": "string"
              },
              "start_line": {
                "type": "integer"
              },
              "end_line": {
                "type": "integer"
              },
              "char_start": {
                "type": "integer"
              },
              "char_end": {
                "type": "integer"
              },
              "excerpt": {
                "type": "string"
              }
            },
            "required": [
              "source_uri"
            ],
            "additionalProperties": false
          },
          "evidence_ref": {
            "type": "string"
          },
          "requires_human_validation": {
            "type": "boolean"
          }
        },
        "required": [
          "field_id",
          "label",
          "value",
          "confidence",
          "source_span",
          "requires_human_validation"
        ],
        "additionalProperties": false
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "synthetic_data_disclaimer": {
      "type": "string"
    }
  },
  "required": [
    "extraction_id",
    "case_id",
    "artifact_id",
    "document_class",
    "extraction_method",
    "extraction_confidence",
    "parser_version",
    "fields",
    "warnings",
    "synthetic_data_disclaimer"
  ],
  "additionalProperties": false
}
