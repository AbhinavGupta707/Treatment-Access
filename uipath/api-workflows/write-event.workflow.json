{
  "document": {
    "dsl": "1.0.0",
    "name": "TreatmentAccessWriteEvent",
    "version": "0.0.1",
    "namespace": "treatment_access.api_workflows",
    "metadata": {
      "variables": {
        "schema": {
          "format": "json",
          "document": {
            "type": "object",
            "properties": {},
            "title": "Variables"
          }
        }
      }
    }
  },
  "input": {
    "schema": {
      "format": "json",
      "document": {
        "type": "object",
        "required": ["apiBaseUrl", "caseId", "action"],
        "properties": {
          "apiBaseUrl": { "type": "string" },
          "caseId": { "type": "string" },
          "maestroCaseId": { "type": "string" },
          "actorName": { "type": "string", "default": "UiPath API Workflow" },
          "taskOrAgentName": { "type": "string", "default": "API Workflow" },
          "action": { "type": "string" },
          "inputSummary": { "type": "string" },
          "outputSummary": { "type": "string" },
          "evidenceRefs": { "type": "array", "items": { "type": "string" }, "default": [] },
          "traceId": { "type": "string" },
          "orchestratorJobId": { "type": "string" }
        },
        "title": "Inputs"
      }
    }
  },
  "output": {
    "schema": {
      "format": "json",
      "document": {
        "type": "object",
        "properties": {
          "workflow": { "type": "string" },
          "caseId": { "type": "string" },
          "eventWrite": { "type": "object" },
          "event": { "type": "object" },
          "eventCount": { "type": "number" },
          "httpStatus": { "type": "number" },
          "syntheticDataOnly": { "type": "boolean" }
        },
        "title": "Outputs"
      }
    }
  },
  "do": [
    {
      "Sequence_1": {
        "do": [
          {
            "WorkflowStart": {
              "set": "${Object.entries($workflow.definition?.document?.metadata?.variables?.schema?.document?.properties || {}).reduce((acc, [name, def]) => ({ ...acc, [name]: def?.default }), {}) }",
              "output": { "as": "${$input}" },
              "export": { "as": "{ ...$context, variables: { ...$context.variables, ...$output } }" },
              "metadata": { "activityType": "Assign", "displayName": "Workflow start", "fullName": "Assign", "isTransparent": true }
            }
          },
          {
            "HttpRequest_WriteEvent": {
              "call": "UiPath.Http",
              "with": {
                "connector": "uipath-uipath-http",
                "connectionId": "ImplicitConnection",
                "connectionResourceId": "ImplicitConnection",
                "method": "POST",
                "endpoint": "/http-request",
                "bodyParameters": {
                  "authentication": "manual",
                  "method": "POST",
                  "url": "${$workflow.input.apiBaseUrl + '/events'}",
                  "headers": { "ContentType": "application/json" },
                  "body": "${{ case_id: $workflow.input.caseId, maestro_case_id: $workflow.input.maestroCaseId, actor_type: 'api_workflow', actor_name: $workflow.input.actorName || 'UiPath API Workflow', task_or_agent_name: $workflow.input.taskOrAgentName || 'API Workflow', action: $workflow.input.action, input_summary: $workflow.input.inputSummary, output_summary: $workflow.input.outputSummary, evidence_refs: $workflow.input.evidenceRefs || [], trace_id: $workflow.input.traceId, orchestrator_job_id: $workflow.input.orchestratorJobId }}"
                }
              },
              "export": { "as": "{ ...$context, outputs: { ...$context?.outputs, \"http_request_1\": $output } }" },
              "metadata": { "fullName": "Connector", "activityType": "Connector", "displayName": "Write Audit Event", "uiPathActivityTypeId": "5c4cc855-b42a-37e6-b910-de8588998fce", "assemblyQualifiedName": "Connector", "configuration": "{\"essentialConfiguration\":{\"connectorVersion\":\"\",\"executionType\":null,\"customFieldsRequestDetails\":null,\"instanceParameters\":{\"version\":\"1.0.0\",\"connectorKey\":\"uipath-uipath-http\",\"activityType\":\"Curated\",\"objectName\":\"http-request\",\"httpMethod\":\"POST\",\"operation\":null,\"eventOperation\":null,\"eventMode\":null,\"connectorObjects\":null,\"previewEndpoint\":null},\"objectName\":\"http-request\",\"operation\":null,\"packageVersion\":\"1.0.0\",\"httpMethod\":\"POST\",\"path\":\"/http-request\",\"unifiedTypesCompatible\":true,\"savedJitInputFieldId\":\"in_http-request\"}}" }
            }
          },
          {
            "Response_1": {
              "response": "${{ workflow: 'write_event', caseId: $workflow.input.caseId, eventWrite: $context.outputs.http_request_1.content, event: $context.outputs.http_request_1.content.event, eventCount: $context.outputs.http_request_1.content.eventCount, httpStatus: $context.outputs.http_request_1.statusCode, syntheticDataOnly: true }}",
              "markJobAsFailed": false,
              "then": "end",
              "export": { "as": "{ ...$context, outputs: { ...$context?.outputs, \"Response_1\": $output } }" },
              "metadata": { "activityType": "Response", "displayName": "Response", "fullName": "Response" }
            }
          }
        ],
        "metadata": { "activityType": "Sequence", "displayName": "Sequence", "fullName": "Sequence" }
      }
    }
  ],
  "evaluate": { "mode": "strict", "language": "javascript" }
}
