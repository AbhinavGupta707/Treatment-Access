{
  "contractSchema": "tacc.actionCenter.quickFormContract.v1",
  "contractVersion": "2026-06-29",
  "taskKey": "human_exception_review",
  "displayName": "Human Exception Review",
  "purpose": "Human reviewer resolves repeated API or portal failure, low-confidence extraction, contradictory evidence, or SLA risk before Maestro resumes the case path.",
  "uiPath": {
    "surface": "Action Center",
    "taskType": "FormTask",
    "formType": "QuickForm",
    "folderName": "TreatmentAccessHackathon",
    "folderId": 7986316,
    "folderKey": "4fba2fa1-012b-469a-b6aa-e5be3811c173",
    "taskCatalog": "Treatment Access Exception Review"
  },
  "assignment": {
    "targetType": "group",
    "targetName": "Treatment Access Case Coordinators",
    "clinicalFallbackGroup": "Treatment Access Clinician Reviewers",
    "fallbackUser": {
      "displayName": "Configured Treatment Access Reviewer",
      "email": "set-during-live-smoke",
      "actionCenterUserId": "set-during-live-smoke",
      "discoveredBy": "uip tasks users 7986316 --output json"
    },
    "channels": ["ActionCenter", "Email"],
    "notes": "Route low-confidence extraction and contradictory evidence to clinician reviewers; route API, portal, and SLA exceptions to case coordinators unless clinical judgment is required."
  },
  "runtime": {
    "priority": "High",
    "timeout": {
      "duration": "PT8H",
      "onTimeout": "raise_urgency",
      "secondaryStage": "SLA At Risk",
      "eventAction": "human.exception.timeout"
    },
    "createWhen": [
      "SubmissionAttempt.retry_count >= 2",
      "PortalFallback.failure_count >= 2",
      "EvidenceArtifact.extraction_confidence < 0.75",
      "EvidenceMapping.status == 'Conflicting'",
      "Case.sla_state in ['at_risk', 'breached']"
    ],
    "exceptionCategories": [
      "repeated_api_failure",
      "repeated_portal_failure",
      "low_confidence_extraction",
      "contradictory_evidence",
      "sla_risk"
    ]
  },
