  "pauseResume": {
    "maestroWaitsOn": "HITL completed handle for node humanExceptionReview1",
    "resumeVariable": "$vars.humanExceptionReview1.output",
    "allowedResumeOutcomes": [
      "Resume Case",
      "Retry API",
      "Route To Robot",
      "Request Clinical Review",
      "Escalate"
    ],
    "caseStateUpdates": {
      "Resume Case": {
        "Case.active_secondary_stages": "clear_current_exception",
        "HumanTask.status": "completed",
        "HumanTask.reviewer_notes": "$output.reviewer_notes"
      },
      "Retry API": {
        "SubmissionAttempt.status": "retry_requested",
        "SubmissionAttempt.retry_count": "$input.attempt_count",
        "Case.active_secondary_stages": "API Failure / Portal Fallback"
      },
      "Route To Robot": {
        "SubmissionAttempt.channel": "portal_robot",
        "SubmissionAttempt.status": "robot_fallback_requested",
        "Case.active_secondary_stages": "API Failure / Portal Fallback"
      },
      "Request Clinical Review": {
        "EvidenceMapping.needs_human_review": true,
        "EvidenceMapping.human_review_reason": "$output.resolution_summary",
        "Case.current_stage": "Clinical Validation"
      },
      "Escalate": {
        "Case.urgency": "high",
        "Case.sla_state": "at_risk",
        "Case.active_secondary_stages": "SLA At Risk"
      }
    }
  },
  "taskCreatedEventPayload": {
    "eventType": "human.task.created",
    "actor_type": "system",
    "actor_name": "Maestro Case",
    "task_or_agent_name": "Human Exception Review",
    "action": "create_action_center_task",
    "case_id": "$input.case_id",
    "maestro_case_id": "$input.maestro_case_id",
    "input_summary": "Created exception review task for $input.exception_category.",
    "output_summary": "Awaiting reviewer routing decision in Action Center.",
    "evidence_refs": ["$input.trace_id"],
    "data_service_updates": ["HumanTask", "AuditEvent"]
  },
  "downstreamEventPayload": {
    "eventType": "human.task.completed",
    "actor_type": "human",
    "actor_name": "$completed_by_display_name",
    "task_or_agent_name": "Human Exception Review",
    "action": "$outcome",
    "case_id": "$input.case_id",
    "maestro_case_id": "$input.maestro_case_id",
    "input_summary": "Reviewer handled $input.exception_category during $input.impacted_stage.",
    "output_summary": "$output.next_action",
    "evidence_refs": ["$input.trace_id", "$output.corrected_value"],
    "data_service_updates": [
      "Case",
      "SubmissionAttempt",
      "EvidenceMapping",
      "AuditEvent",
      "HumanTask"
    ]
  },
  "guardrails": [
    "Do not complete the exception task automatically.",
    "Low-confidence or contradictory clinical evidence must route back to clinical validation before submission.",
    "Repeated API or portal failures must leave an audit event even when the reviewer chooses retry."
  ]
