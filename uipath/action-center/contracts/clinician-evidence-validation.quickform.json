    "folderKey": "4fba2fa1-012b-469a-b6aa-e5be3811c173",
    "taskCatalog": "Treatment Access Clinical Review"
  },
  "assignment": {
    "targetType": "group",
    "targetName": "Treatment Access Clinician Reviewers",
    "fallbackUser": {
      "displayName": "Configured Treatment Access Reviewer",
      "email": "set-during-live-smoke",
      "actionCenterUserId": "set-during-live-smoke",
      "discoveredBy": "uip tasks users 7986316 --output json"
    },
    "channels": ["ActionCenter", "Email"],
    "notes": "Use group assignment for live demo once the reviewer group exists. The fallback user is the only assignable user discovered in folder 7986316 during this lane."
  },
  "runtime": {
    "priority": "High",
    "timeout": {
      "duration": "PT24H",
      "onTimeout": "activate_secondary_stage",
      "secondaryStage": "Human Exception Review",
      "eventAction": "human.task.timeout"
    },
    "createWhen": [
      "EvidenceMapping.needs_human_review == true",
      "PolicyCriterion.must_be_clinician_attested == true",
      "EvidenceMapping.confidence < 0.85",
      "EvidenceMapping.status == 'Conflicting'"
    ]
  },
