  "taskKey": "clinician_evidence_validation",
  "displayName": "Clinician Evidence Validation",
  "purpose": "Clinician validates a mapped evidence claim, source citation, policy criterion, and confidence before the claim can be used in a submission packet.",
  "uiPath": {
    "surface": "Action Center",
    "taskType": "FormTask",
    "formType": "QuickForm",
