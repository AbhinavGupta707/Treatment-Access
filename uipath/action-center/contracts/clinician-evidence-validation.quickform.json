  "pauseResume": {
    "maestroWaitsOn": "HITL completed handle for node clinicianEvidenceValidation1",
    "resumeVariable": "$vars.clinicianEvidenceValidation1.output",
    "allowedResumeOutcomes": [
      "Approve",
      "Approve With Edits",
      "Reject",
      "Request More Evidence"
    ],
    "caseStateUpdates": {
      "Approve": {
        "EvidenceMapping.reviewer_decision": "approved",
        "EvidenceMapping.reviewer_final_text": "$output.reviewer_final_text",
        "EvidenceMapping.reviewed_at": "$completed_at",
        "EvidenceMapping.reviewer_id": "$completed_by",
        "EvidenceMapping.needs_human_review": false
      },
      "Approve With Edits": {
        "EvidenceMapping.reviewer_decision": "approved_with_edits",
        "EvidenceMapping.reviewer_original_text": "$input.evidence_summary",
        "EvidenceMapping.reviewer_final_text": "$output.reviewer_final_text",
        "EvidenceMapping.reviewed_at": "$completed_at",
        "EvidenceMapping.reviewer_id": "$completed_by",
        "EvidenceMapping.needs_human_review": false
      },
      "Reject": {
        "EvidenceMapping.reviewer_decision": "rejected",
        "EvidenceMapping.needs_human_review": true,
        "Case.active_secondary_stages": "Clinician Rework"
      },
      "Request More Evidence": {
        "EvidenceMapping.reviewer_decision": "more_evidence_requested",
        "EvidenceMapping.human_review_reason": "$output.more_evidence_reason",
        "Case.active_secondary_stages": "Missing Evidence"
      }
    }
  },
