    "taskCatalog": "Treatment Access Clinical Review"
  },
  "assignment": {
    "targetType": "group",
    "targetName": "Treatment Access Clinician Reviewers",
    "fallbackUser": {
      "displayName": "Configured Treatment Access Reviewer",
      "email": "set-during-live-smoke",
      "actionCenterUserId": "set-during-live-smoke",
      "discoveredBy": "uip tasks users 7986316 --output json"
    },
    "channels": ["ActionCenter", "Email"],
    "notes": "Appeal signoff must be completed by a clinician reviewer before the appeal submission API Workflow runs."
  },
  "runtime": {
    "priority": "Critical",
    "timeout": {
      "duration": "PT12H",
      "onTimeout": "activate_secondary_stage",
      "secondaryStage": "SLA At Risk",
      "eventAction": "human.task.timeout"
    },
    "createWhen": [
      "PayerDecision.status in ['denied', 'rfi']",
      "AppealPacket.draft_text exists",
      "AppealPacket.clinician_approved != true"
    ]
  },
