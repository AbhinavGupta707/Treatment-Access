  "pauseResume": {
    "maestroWaitsOn": "HITL completed handle for node appealSignoff1",
    "resumeVariable": "$vars.appealSignoff1.output",
    "allowedResumeOutcomes": [
      "Approve Appeal",
      "Approve With Edits",
      "Request Changes",
      "Reject Appeal"
    ],
    "caseStateUpdates": {
      "Approve Appeal": {
        "AppealPacket.clinician_approved": true,
        "AppealPacket.draft_text": "$output.final_draft_text",
        "AppealPacket.clinician_edits": "$output.clinician_edits",
        "SubmissionPacket.human_approved": true,
        "Case.current_stage": "Denial Rescue / Appeal"
      },
      "Approve With Edits": {
        "AppealPacket.clinician_approved": true,
        "AppealPacket.draft_text": "$output.final_draft_text",
        "AppealPacket.clinician_edits": "$output.clinician_edits",
        "SubmissionPacket.human_approved": true,
        "Case.current_stage": "Denial Rescue / Appeal"
      },
      "Request Changes": {
        "AppealPacket.clinician_approved": false,
        "AppealPacket.clinician_edits": "$output.rejection_reason",
        "Case.active_secondary_stages": "Clinician Rework"
      },
      "Reject Appeal": {
        "AppealPacket.clinician_approved": false,
        "AppealPacket.clinician_edits": "$output.rejection_reason",
        "Case.active_secondary_stages": "Clinician Rework"
      }
    }
