{
  "id": "612453a9-9fb6-411d-b198-8e8d696521fb",
  "version": "1.3",
  "name": "ClinicianValidationFlow",
  "runtime": "maestro",
  "nodes": [
    {
      "id": "start",
      "type": "core.trigger.manual",
      "typeVersion": "1.0",
      "display": {
        "label": "Manual trigger"
      },
      "inputs": {
        "entryPointId": "51410337-da8c-48a9-aee7-ef1db7cf2fa6",
        "isDefaultEntryPoint": true
      }
    },
    {
      "id": "clinicianEvidenceReview1",
      "type": "uipath.human-in-the-loop",
      "typeVersion": "1.0",
      "display": {
        "label": "Clinician Evidence Review"
      },
      "inputs": {
        "type": "quick",
        "schema": {
          "schemaId": "ee0b87c9-407b-45b4-852e-9437ed0ec055",
          "fields": [
            {
              "id": "ExternalTag",
              "label": "Case external tag",
              "type": "text",
              "direction": "input",
              "binding": "vars.externalTag"
            },
            {
              "id": "clinicalAttestation",
              "label": "Clinical attestation",
              "type": "text",
              "direction": "output",
              "variable": "clinicalAttestation",
              "required": true
            },
            {
              "id": "reviewNotes",
              "label": "Review notes",
              "type": "text",
              "direction": "output",
              "variable": "reviewNotes",
              "required": false
            }
          ],
          "outcomes": [
            {
              "id": "approve-packet",
              "name": "Approve packet",
              "type": "string",
              "isPrimary": true,
              "action": "Continue"
            },
            {
              "id": "request-more-evidence",
              "name": "Request more evidence",
              "type": "string",
              "isPrimary": false,
              "action": "End"
            }
          ]
        },
        "recipient": {
          "channels": [
            "Email",
            "ActionCenter"
          ],
          "connections": {},
          "assignee": {
            "type": "staticEmail",
            "value": "clinician.reviewer@example.com"
          }
        },
        "title": "Clinician Evidence Review",
        "priority": "High"
      },
      "outputs": {
        "output": {
          "type": "object",
          "description": "Task result data",
          "source": "=result",
          "var": "output",
          "properties": {
            "clinicalAttestation": {
              "type": "string"
            },
            "reviewNotes": {
              "type": "string"
            },
            "Action": {
              "type": "string",
              "enum": [
                "Approve packet",
                "Request more evidence"
              ],
              "default": "Approve packet"
            }
          }
        },
        "status": {
          "type": "string",
          "description": "Task completion status",
          "source": "=result.Action",
          "var": "status",
          "enum": [
            "Approve packet",
            "Request more evidence"
          ],
          "default": "Approve packet"
        }
      }
    },
    {
      "id": "humanGateRecorded1",
      "type": "core.control.end",
      "typeVersion": "1.0",
      "display": {
        "label": "Human gate recorded"
      },
      "inputs": {},
      "outputs": {
        "clinicalAttestation": {
          "source": "=js:$vars.clinicianEvidenceReview1.output.clinicalAttestation"
        },
        "reviewNotes": {
          "source": "=js:$vars.clinicianEvidenceReview1.output.reviewNotes"
        }
      }
    },
    {
      "id": "prepareSyntheticReviewPacket1",
      "type": "core.logic.mock",
      "typeVersion": "1.0",
      "display": {
        "label": "Prepare synthetic review packet"
      },
      "inputs": {}
    }
  ],
  "edges": [
    {
      "id": "start-output-prepareSyntheticReviewPacket1-input",
      "sourceNodeId": "start",
      "sourcePort": "output",
      "targetNodeId": "prepareSyntheticReviewPacket1",
      "targetPort": "input"
    },
    {
      "id": "prepareSyntheticReviewPacket1-output-clinicianEvidenceReview1-input",
      "sourceNodeId": "prepareSyntheticReviewPacket1",
      "sourcePort": "output",
      "targetNodeId": "clinicianEvidenceReview1",
      "targetPort": "input"
    },
    {
      "id": "clinicianEvidenceReview1-completed-humanGateRecorded1-input",
      "sourceNodeId": "clinicianEvidenceReview1",
      "sourcePort": "completed",
      "targetNodeId": "humanGateRecorded1",
      "targetPort": "input"
    }
  ],
  "definitions": [
    {
      "nodeType": "core.trigger.manual",
      "version": "1.0",
      "description": "Start workflow manually",
      "category": "trigger",
      "tags": [
        "trigger",
        "start",
        "manual"
      ],
      "sortOrder": 40,
      "display": {
        "label": "Manual trigger",
        "icon": "play",
        "shape": "circle"
      },
      "handleConfiguration": [
        {
          "position": "right",
          "handles": [
            {
              "id": "output",
              "type": "source",
              "handleType": "output",
              "showButton": true,
              "constraints": {
                "forbiddenTargetCategories": [
                  "trigger"
                ]
              }
            }
          ],
          "visible": true
        }
      ],
      "toolbarExtensions": {
        "design": {
          "actions": [
            {
              "id": "change-trigger-type",
              "icon": "square-mouse-pointer",
              "label": "Change trigger type"
            }
          ]
        }
      },
      "outputDefinition": {
        "output": {
          "type": "object",
          "description": "Data passed when manually triggering the workflow.",
          "source": "null",
          "var": "output"
        }
      },
      "model": {
        "type": "bpmn:StartEvent",
        "entryPointId": true
      }
    },
    {
      "nodeType": "uipath.human-in-the-loop",
      "version": "1.0",
      "sortOrder": 50,
      "category": "human-task",
      "description": "Pause flow execution and wait for a human to complete a task",
      "tags": [
        "human-task",
        "hitl",
        "human-in-the-loop",
        "approval"
      ],
      "display": {
        "label": "Clinician Evidence Review",
        "icon": "users",
        "shape": "square"
      },
      "handleConfiguration": [
        {
          "position": "left",
          "handles": [
            {
              "id": "input",
              "type": "target",
              "handleType": "input",
              "constraints": {
                "forbiddenSourceCategories": [
                  "trigger"
                ],
                "validationMessage": "Human tasks cannot be directly triggered"
              }
            }
          ],
          "visible": true
        },
        {
          "position": "right",
          "handles": [
            {
              "id": "completed",
              "label": "Completed",
              "type": "source",
              "handleType": "output",
              "showButton": true,
              "constraints": {
                "forbiddenTargetCategories": [
                  "trigger"
                ]
              }
            }
          ],
          "visible": true
        }
      ],
      "model": {
        "type": "bpmn:UserTask",
        "serviceType": "Actions.HITL"
      },
      "inputDefinition": {
        "type": "quick",
        "schema": {
          "fields": [],
          "outcomes": [
            {
              "id": "submit",
              "name": "Submit",
              "type": "string",
              "isPrimary": true,
              "action": "Continue"
            }
          ]
        },
        "recipient": {
          "channels": [
            "Email",
            "ActionCenter"
          ],
          "connections": {},
          "assignee": {
            "type": "group"
          }
        }
      },
      "outputDefinition": {
        "output": {
          "type": "object",
          "description": "Task result data",
          "source": "=result",
          "var": "output"
        },
        "status": {
          "type": "string",
          "description": "Task completion outcome",
          "source": "=result.Action",
          "var": "status"
        }
      }
    },
    {
      "nodeType": "core.control.end",
      "version": "1.0",
      "category": "control-flow",
      "description": "Mark the end of a workflow path",
      "tags": [
        "control-flow",
        "end",
        "finish",
        "complete"
      ],
      "sortOrder": 20,
      "display": {
        "label": "End",
        "icon": "circle-check",
        "shape": "circle"
      },
      "handleConfiguration": [
        {
          "position": "left",
          "handles": [
            {
              "id": "input",
              "type": "target",
              "handleType": "input"
            }
          ]
        }
      ],
      "model": {
        "type": "bpmn:EndEvent"
      },
      "runtimeConstraints": {
        "exclude": [
          "api-function"
        ]
      }
    },
    {
      "nodeType": "core.logic.mock",
      "version": "1.0",
      "category": "control-flow",
      "description": "Placeholder node for prototyping",
      "tags": [
        "blank",
        "todo"
      ],
      "sortOrder": 20,
      "display": {
        "label": "Mock",
        "icon": "square-dashed"
      },
      "handleConfiguration": [
        {
          "position": "left",
          "handles": [
            {
              "id": "input",
              "type": "target",
              "handleType": "input"
            }
          ],
          "visible": true
        },
        {
          "position": "right",
          "handles": [
            {
              "id": "output",
              "type": "source",
              "handleType": "output"
            }
          ],
          "visible": true
        }
      ],
      "model": {
        "type": "bpmn:Task"
      },
      "outputDefinition": {
        "output": {
          "type": "object",
          "description": "Mock output value",
          "source": "null",
          "var": "output"
        }
      },
      "runtimeConstraints": {
        "exclude": [
          "api-function"
        ]
      }
    }
  ],
  "variables": {
    "nodes": [
      {
        "id": "start.output",
        "type": "object",
        "description": "Data passed when manually triggering the workflow.",
        "binding": {
          "nodeId": "start",
          "outputId": "output"
        }
      },
      {
        "id": "clinicianEvidenceReview1.output",
        "type": "object",
        "description": "Task result data",
        "binding": {
          "nodeId": "clinicianEvidenceReview1",
          "outputId": "output"
        }
      },
      {
        "id": "clinicianEvidenceReview1.status",
        "type": "string",
        "description": "Task completion status",
        "binding": {
          "nodeId": "clinicianEvidenceReview1",
          "outputId": "status"
        }
      },
      {
        "id": "humanGateRecorded1.clinicalAttestation",
        "type": "string",
        "binding": {
          "nodeId": "humanGateRecorded1",
          "outputId": "clinicalAttestation"
        }
      },
      {
        "id": "humanGateRecorded1.reviewNotes",
        "type": "string",
        "binding": {
          "nodeId": "humanGateRecorded1",
          "outputId": "reviewNotes"
        }
      },
      {
        "id": "prepareSyntheticReviewPacket1.output",
        "type": "object",
        "description": "Mock output value",
        "binding": {
          "nodeId": "prepareSyntheticReviewPacket1",
          "outputId": "output"
        }
      }
    ],
    "globals": [
      {
        "id": "clinicalAttestation",
        "direction": "out",
        "type": "string"
      },
      {
        "id": "reviewNotes",
        "direction": "out",
        "type": "string"
      },
      {
        "id": "externalTag",
        "direction": "in",
        "type": "string",
        "defaultValue": "TACC-2026-001",
        "description": "Synthetic case external tag for Action Center task correlation."
      }
    ]
  },
