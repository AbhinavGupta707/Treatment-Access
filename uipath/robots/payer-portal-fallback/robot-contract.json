{
  "robotId": "payer-portal-fallback",
  "displayName": "Payer Portal Fallback",
  "orchestratorFolder": {
    "name": "TreatmentAccessHackathon",
    "key": "4fba2fa1-012b-469a-b6aa-e5be3811c173"
  },
  "syntheticDataOnly": true,
  "inputs": {
    "portalUrl": {
      "type": "string",
      "asset": "TACC_PAYER_PORTAL_URL",
      "example": "http://127.0.0.1:8788"
    },
    "apiBaseUrl": {
      "type": "string",
      "asset": "TACC_MOCK_API_BASE_URL",
      "example": "http://127.0.0.1:8787"
    },
    "caseId": {
      "type": "string",
      "example": "case-demo-001"
    },
    "patientId": {
      "type": "string",
      "example": "patient-synth-001"
    },
    "orderId": {
      "type": "string",
      "example": "order-synth-001"
    },
    "memberId": {
      "type": "string",
      "portalTarget": "member ID field"
    },
    "medication": {
      "type": "string",
      "portalTarget": "medication field"
    },
    "diagnosis": {
      "type": "string",
      "portalTarget": "diagnosis field"
    },
    "evidenceRefs": {
      "type": "array",
      "items": "string"
    },
    "demoRunId": {
      "type": "string"
    }
  },
  "optionalInputs": {
    "portalUsername": {
      "type": "string",
      "asset": "TACC_PAYER_PORTAL_USERNAME",
      "note": "Synthetic credential only if the mock portal lane adds login."
    },
    "portalPassword": {
      "type": "credential",
      "asset": "TACC_PAYER_PORTAL_PASSWORD",
      "note": "Synthetic credential only if the mock portal lane adds login."
    }
  },
  "portalContract": {
    "form": "prior authorization submission form",
    "fields": ["member ID", "medication", "diagnosis"],
    "submit": "submit button",
    "confirmation": "confirmation region containing confirmation ID"
  },
  "fallbackStateMachine": {
    "description": "Synthetic portal fallback proof states. These distinguish API failure, robot request preparation, and portal confirmation without implying a real payer submission.",
    "states": [
      {
        "state": "api_unavailable",
        "mirrorAction": "payer_prior_auth_unavailable",
        "actorType": "api_workflow",
        "source": "mock_api_event_mirror",
        "terminal": false,
        "summary": "Payer API returned PAYER_API_DOWN; portal fallback is required."
      },
      {
        "state": "robot_requested",
        "mirrorAction": "robot_fallback_requested",
        "actorType": "robot",
        "source": "uipath_robot_event",
        "terminal": false,
        "summary": "UiPath robot fallback request was prepared; no live robot job has started by default."
      },
      {
        "state": "confirmation_received",
        "mirrorAction": "payer_portal_fallback_submitted",
        "actorType": "robot",
        "source": "uipath_robot_event",
        "terminal": true,
        "summary": "Synthetic portal confirmation was read from the local mock portal after approved portal submission."
      }
    ],
    "transitions": [
      {
        "from": "api_unavailable",
        "to": "robot_requested",
        "requiresApproval": false,
        "sideEffect": false
      },
      {
        "from": "robot_requested",
        "to": "confirmation_received",
        "requiresApproval": true,
        "sideEffect": true,
        "approvalGate": "live-smoke-approval-gate.md"
      }
    ]
  },
  "outputs": {
    "status": {
      "type": "string",
      "allowedValues": [
        "api_unavailable",
        "robot_requested",
        "confirmation_received",
        "failed"
      ]
    },
    "confirmationId": {
      "type": "string",
      "source": "portal confirmation region",
      "availableWhen": "status=confirmation_received"
    },
    "robotJobId": {
      "type": "string",
      "source": "UiPath Orchestrator job ID when invoked as process",
      "availableWhen": "approved live RPA run/debug or Orchestrator job start has occurred"
    },
    "fallbackRequestEvent": {
      "type": "object",
      "action": "robot_fallback_requested",
      "actor": "robot",
      "requiredFields": [
        "caseId",
        "robotProcessName",
        "orchestratorFolder",
        "reasonCode",
        "demoRunId"
      ]
    },
    "fallbackEvent": {
      "type": "object",
      "action": "payer_portal_fallback_submitted",
      "actor": "robot",
      "requiredFields": [
        "caseId",
        "confirmationId",
        "robotJobId",
        "portalUrl",
        "demoRunId"
      ]
    }
  },
  "safetyGates": [
    "Use synthetic case, patient, payer, provider, credential, and portal data only.",
    "Do not submit real payer requests.",
    "Every clinical assertion in the packet must already be supported by CP3 agent evidence, policy citation, or human approval.",
    "Appeal or medical-necessity text is not generated or adjudicated by this robot."
  ]
}
